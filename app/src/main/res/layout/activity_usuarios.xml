<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fond"
    android:fitsSystemWindows="true">

    <!-- Botón Regresar -->
    <ImageView
        android:id="@+id/btn_regresar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_regreso"
        android:contentDescription="Regresar"
        android:scaleType="centerInside" />

    <!-- Título -->
    <TextView
        android:id="@+id/tv_titulo_usuarios"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Administrar Usuarios"
        android:textColor="#FFCC00"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Contenedor horizontal para buscador y filtro -->
    <LinearLayout
        android:id="@+id/ll_contenedor_filtros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_titulo_usuarios"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Buscador -->
        <EditText
            android:id="@+id/et_buscador"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1.8"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_campo_perfil"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="12dp"
            android:hint="Nombre o carnet"
            android:padding="12dp"
            android:textColor="@android:color/white"
            android:textColorHint="#B3FFFFFF"
            android:inputType="text"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- Spinner Filtro -->
        <Spinner
            android:id="@+id/spinner_filtro_tipo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_campo_perfil"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:popupBackground="#333333"
            android:spinnerMode="dropdown"
            android:gravity="center"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- RecyclerView de usuarios -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_usuarios"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/ll_contenedor_filtros"
        android:layout_above="@id/ll_paginacion"
        android:layout_marginTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />

    <!-- ✅ NUEVO: Barra de paginación en la parte inferior -->
    <LinearLayout
        android:id="@+id/ll_paginacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#1A1A1A"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:baselineAligned="false">

        <!-- Botón página anterior -->
        <ImageView
            android:id="@+id/btn_anterior_pagina"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Página anterior"
            android:scaleType="centerInside"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Información de paginación -->
        <TextView
            android:id="@+id/tv_paginacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Página 1 de 10"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:gravity="center"
            android:textStyle="bold" />

        <!-- Botón página siguiente -->
        <ImageView
            android:id="@+id/btn_siguiente_pagina"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Página siguiente"
            android:scaleType="centerInside"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- Botón flotante para agregar usuario -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_agregar_usuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_above="@id/ll_paginacion"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#2196F3"
        app:tint="@android:color/white"
        android:contentDescription="Agregar usuario" />

</RelativeLayout>