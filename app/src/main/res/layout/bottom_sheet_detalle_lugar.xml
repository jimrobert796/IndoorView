<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    app:behavior_peekHeight="120dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Barra de arrastre -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#CCCCCC"
        android:alpha="0.6" />

    <!-- Título con contador de fotos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_titulo_lugar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edificio tal"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_contador_fotos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:background="#33000000"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Contenedor de descripción -->
    <LinearLayout
        android:id="@+id/ll_descripcion_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="26dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_editar_descripcion"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Editar descripción"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_descripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- Carrusel de fotos -->
    <HorizontalScrollView
        android:id="@+id/hsv_fotos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:overScrollMode="never"
        android:fadingEdgeLength="50dp">

        <LinearLayout
            android:id="@+id/ll_fotos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <!-- Foto 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_foto1"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false">

                <ImageView
                    android:id="@+id/iv_foto1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_placeholder"
                    android:transitionName="foto_transition_1" />

            </androidx.cardview.widget.CardView>

            <!-- Foto 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_foto2"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false">

                <ImageView
                    android:id="@+id/iv_foto2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_placeholder"
                    android:transitionName="foto_transition_2" />

            </androidx.cardview.widget.CardView>

            <!-- Foto 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_foto3"
                android:layout_width="280dp"
                android:layout_height="280dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardPreventCornerOverlap="false">

                <ImageView
                    android:id="@+id/iv_foto3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_placeholder"
                    android:transitionName="foto_transition_3" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Indicador de página (dots) -->
    <LinearLayout
        android:id="@+id/ll_indicador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone" />

</LinearLayout>