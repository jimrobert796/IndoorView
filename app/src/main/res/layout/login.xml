<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/fondo_imagen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondo_login"
        android:scaleType="centerCrop"
        android:contentDescription="Fondo" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_formulario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_margin="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/transparent">  <!-- 👈 Importante: transparente -->

                <!-- El gradiente lo pones en un layout interno -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/gradiente_card"
                    android:padding="24dp">

                    <!-- Todo tu contenido del login va aquí -->
                    <ImageView
                        android:id="@+id/logo_universidad"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:src="@drawable/logo_universidad"
                        android:contentDescription="Logo universidad" />

                    <TextView
                        android:id="@+id/titulo_app"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/logo_universidad"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="12dp"
                        android:text="Bienvenidos/as"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Campo Carnet -->
                    <TextView
                        android:id="@+id/label_carnet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/titulo_app"
                        android:layout_marginTop="30dp"
                        android:text="Introduzca su carnet"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/input_carnet"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_below="@id/label_carnet"
                        android:layout_marginTop="8dp"
                        android:background="@android:drawable/editbox_background"
                        android:hint="Ej: 20240001"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Campo Contraseña -->
                    <TextView
                        android:id="@+id/label_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/input_carnet"
                        android:layout_marginTop="20dp"
                        android:text="Contraseña"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/input_password"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_below="@id/label_password"
                        android:layout_marginTop="8dp"
                        android:background="@android:drawable/editbox_background"
                        android:hint="Ingrese su contraseña"
                        android:inputType="textPassword"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Botón -->
                    <Button
                        android:id="@+id/btn_login"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_below="@id/input_password"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#3B82F6"
                        android:text="Inicia sesión"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Olvidó contraseña -->
                    <TextView
                        android:id="@+id/tv_forgot_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/btn_login"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:text="Olvidó su contraseña?"
                        android:textColor="#60A5FA"
                        android:textSize="14sp"
                        android:padding="8dp" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </RelativeLayout>
    </ScrollView>
</RelativeLayout>