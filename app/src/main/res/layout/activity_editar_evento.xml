<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fond"
    android:fitsSystemWindows="true">

    <!-- Botón Regresar -->
    <ImageView
        android:id="@+id/btn_regresar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="30dp"
        android:padding="5dp"
        android:src="@drawable/ic_regreso"
        android:clickable="true"
        android:focusable="true"
        android:elevation="10dp"
        android:contentDescription="Regresar" />

    <!-- ScrollView para pantallas pequeñas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Contenedor centrado -->
            <RelativeLayout
                android:id="@+id/contenedor_centrado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">

                <!-- Título del formulario -->
                <TextView
                    android:id="@+id/tv_titulo_formulario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crear / Editar Evento"
                    android:textColor="#FFCC00"
                    android:layout_marginTop="40dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <!-- Card del formulario -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_formulario_evento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_titulo_formulario"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#80000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Título del evento -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Título del evento"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_titulo_evento"
                            android:layout_width="match_parent"
                            android:layout_height="76dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/bg_campo_perfil"
                            android:hint="Ej: Conferencia de Tecnología"
                            android:textSize="14dp"
                            android:gravity="top"
                            android:padding="12dp"
                            android:inputType="textMultiLine"
                            android:textColor="@android:color/white"
                            android:textColorHint="#B3FFFFFF"
                            android:scrollbarAlwaysDrawHorizontalTrack="true"/>

                        <!-- Información del evento -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Información del evento"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/et_descripcion"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginBottom="16dp"
                            android:background="@drawable/bg_campo_perfil"
                            android:hint="Descripción del evento..."
                            android:gravity="top"
                            android:textSize="14dp"
                            android:padding="12dp"
                            android:inputType="textMultiLine"
                            android:textColor="@android:color/white"
                            android:textColorHint="#B3FFFFFF"
                            android:scrollbarAlwaysDrawHorizontalTrack="true"/>

                        <!-- Punto de referencia -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Punto de referencia"
                            android:textColor="#B3FFFFFF"
                            android:textSize="12sp"
                            android:layout_marginBottom="8dp" />

                        <Button
                            android:id="@+id/btn_agregar_punto"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:backgroundTint="#2196F3"
                            android:text="Agregar punto"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="20dp" />

                        <!-- Separador -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#33FFFFFF"
                            android:layout_marginBottom="20dp" />

                        <!-- Título sección fecha/hora -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha y hora del evento"
                            android:textColor="#FFCC00"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp" />

                        <!-- Fecha Inicio -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fecha inicio"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <EditText
                                    android:id="@+id/et_fecha_inicio"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_campo_perfil"
                                    android:hint="dd/mm/aaaa"
                                    android:padding="12dp"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"
                                    android:textColor="@android:color/white"
                                    android:textColorHint="#B3FFFFFF" />

                                <ImageButton
                                    android:id="@+id/btn_fecha_inicio"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_campo_perfil"
                                    android:src="@android:drawable/ic_menu_today"
                                    android:contentDescription="Seleccionar fecha"
                                    android:padding="12dp"
                                    android:tint="#FFFFFF" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Fecha Fin -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fecha fin"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <EditText
                                    android:id="@+id/et_fecha_fin"
                                    android:layout_width="0dp"
                                    android:layout_height="56dp"
                                    android:layout_weight="1"
                                    android:background="@drawable/bg_campo_perfil"
                                    android:hint="dd/mm/aaaa"
                                    android:padding="12dp"
                                    android:focusable="false"
                                    android:clickable="true"
                                    android:inputType="none"
                                    android:textColor="@android:color/white"
                                    android:textColorHint="#B3FFFFFF" />

                                <ImageButton
                                    android:id="@+id/btn_fecha_fin"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_campo_perfil"
                                    android:src="@android:drawable/ic_menu_today"
                                    android:contentDescription="Seleccionar fecha fin"
                                    android:padding="12dp"
                                    android:tint="#FFFFFF" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Horas Inicio y Fin -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp">

                            <!-- Hora inicio -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hora inicio"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <EditText
                                        android:id="@+id/et_hora_inicio"
                                        android:layout_width="0dp"
                                        android:layout_height="56dp"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_campo_perfil"
                                        android:hint="hh:mm"
                                        android:padding="12dp"
                                        android:focusable="false"
                                        android:clickable="true"
                                        android:inputType="none"
                                        android:textColor="@android:color/white"
                                        android:textColorHint="#B3FFFFFF" />

                                    <ImageButton
                                        android:id="@+id/btn_hora_inicio"
                                        android:layout_width="56dp"
                                        android:layout_height="56dp"
                                        android:layout_marginStart="8dp"
                                        android:background="@drawable/bg_campo_perfil"
                                        android:src="@android:drawable/ic_menu_recent_history"
                                        android:contentDescription="Seleccionar hora inicio"
                                        android:padding="12dp"
                                        android:tint="#FFFFFF" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Hora fin -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Hora fin"
                                    android:textColor="#B3FFFFFF"
                                    android:textSize="12sp"
                                    android:layout_marginBottom="4dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <EditText
                                        android:id="@+id/et_hora_fin"
                                        android:layout_width="0dp"
                                        android:layout_height="56dp"
                                        android:layout_weight="1"
                                        android:background="@drawable/bg_campo_perfil"
                                        android:hint="hh:mm"
                                        android:padding="12dp"
                                        android:focusable="false"
                                        android:clickable="true"
                                        android:inputType="none"
                                        android:textColor="@android:color/white"
                                        android:textColorHint="#B3FFFFFF" />

                                    <ImageButton
                                        android:id="@+id/btn_hora_fin"
                                        android:layout_width="56dp"
                                        android:layout_height="56dp"
                                        android:layout_marginStart="8dp"
                                        android:background="@drawable/bg_campo_perfil"
                                        android:src="@android:drawable/ic_menu_recent_history"
                                        android:contentDescription="Seleccionar hora fin"
                                        android:padding="12dp"
                                        android:tint="#FFFFFF" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Botón Guardar -->
                        <Button
                            android:id="@+id/btn_guardar_evento"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="#2196F3"
                            android:text="Guardar Evento"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </RelativeLayout>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>