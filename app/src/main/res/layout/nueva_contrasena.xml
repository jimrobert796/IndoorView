<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Imagen de fondo -->
    <ImageView
        android:id="@+id/fondo_imagen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fond"
        android:scaleType="centerCrop"
        android:contentDescription="Fondo" />


    <ImageView
        android:id="@+id/btn_regresar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_regreso"
        android:contentDescription="Regresar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- Contenedor principal centrado -->
            <RelativeLayout
                android:id="@+id/contenedor_centrado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">

                <!-- nueva contraseña -->
                <TextView
                    android:id="@+id/tv_titulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nueva Contraseña"
                    android:textColor="#FFCC00"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <!-- subtitulo -->
                <TextView
                    android:id="@+id/tv_subtitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_titulo"
                    android:layout_marginTop="12dp"
                    android:text="Por favor escribe tu nueva contraseña"
                    android:textColor="#E0E0E0"
                    android:textSize="14sp"
                    android:gravity="center" />

                <!-- Contraseña -->
                <TextView
                    android:id="@+id/label_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_subtitulo"
                    android:layout_marginTop="32dp"
                    android:text="Contraseña"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_below="@id/label_password"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_campo_perfil"
                    android:hint="Ingrese su nueva contraseña"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B3FFFFFF" />

                <!-- Confirmar Contraseña -->
                <TextView
                    android:id="@+id/label_confirm_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/et_password"
                    android:layout_marginTop="16dp"
                    android:text="Confirmar contraseña"
                    android:textColor="#B3FFFFFF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_below="@id/label_confirm_password"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_campo_perfil"
                    android:hint="Confirme su nueva contraseña"
                    android:inputType="textPassword"
                    android:padding="12dp"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B3FFFFFF" />

                <!-- Botón Confirmar Contraseña -->
                <Button
                    android:id="@+id/btn_confirmar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_below="@id/et_confirm_password"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="#2196F3"
                    android:text="Confirmar Contraseña"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </RelativeLayout>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>