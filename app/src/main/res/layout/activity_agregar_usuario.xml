<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fond">

    <!-- Botón Regresar -->
    <ImageView
        android:id="@+id/btn_regresar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:padding="8dp"
        android:src="@drawable/ic_regreso"
        android:contentDescription="Regresar" />

    <!-- ScrollView para pantallas pequeñas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Card del formulario (ocupa todo el ancho) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_formulario_usuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#80000000"> <!-- si se puede quitar o no se ve bien, quitalo maje ya sea jimmy o vos, y hola a quien lea esto jejejejej -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Imagen de perfil (circular) -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:id="@+id/iv_imagen_perfil"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center_horizontal"
                            android:src="@drawable/imagen_perfil"
                            android:contentDescription="Foto de perfil"
                            app:circleCrop="true" />

                    </FrameLayout>

                    <!-- Campo: Carnet -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carnet"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_carnet"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_campo_perfil"
                        android:hint="Ej: 20240001"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Campo: Nombres -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombres"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_nombres"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_campo_perfil"
                        android:hint="Ej: Luis Eduardo"
                        android:inputType="textPersonName"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Campo: Apellidos -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Apellidos"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_apellidos"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_campo_perfil"
                        android:hint="Ej: Hernández Pérez"
                        android:inputType="textPersonName"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Campo: Correo -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Correo"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_correo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_campo_perfil"
                        android:hint="Ej: usuario@ugb.edu.sv"
                        android:inputType="textEmailAddress"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Campo: Contraseña -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Contraseña"
                        android:textColor="#B3FFFFFF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_campo_perfil"
                        android:hint="Ingrese contraseña"
                        android:inputType="textPassword"
                        android:padding="12dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />

                    <!-- Botones (horizontal) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Botón Cancelar -->
                        <Button
                            android:id="@+id/btn_cancelar"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="#757575"
                            android:text="Cancelar"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- Botón Guardar -->
                        <Button
                            android:id="@+id/btn_guardar_usuario"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="#2196F3"
                            android:text="Guardar Usuario"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>