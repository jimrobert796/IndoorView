<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#80000000">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Nombre del usuario -->
        <TextView
            android:id="@+id/tv_nombre_usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:text="usuario"
            android:textColor="#FFCC00"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Carnet del usuario -->
        <TextView
            android:id="@+id/tv_carnet_usuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_nombre_usuario"
            android:layout_alignParentStart="true"
            android:layout_marginTop="4dp"
            android:text="USSS019225"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <!-- Botón de 3 puntos (menú contextual) -->
        <ImageView
            android:id="@+id/iv_menu_usuario"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@drawable/ic_menu_vertical"
            android:contentDescription="Opciones" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>