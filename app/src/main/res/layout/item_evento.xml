<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_evento"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"   
    app:cardElevation="4dp"
    app:cardBackgroundColor="#80000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Título del evento -->
        <TextView
            android:id="@+id/tv_titulo_evento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Conferencia de Tecnología"
            android:textColor="#FFCC00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_hora_inicio" />

        <!-- Hora de inicio -->
        <TextView
            android:id="@+id/tv_hora_inicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="19:00"
            android:textColor="#60A5FA"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_titulo_evento" />

        <!-- Descripción del evento -->
        <TextView
            android:id="@+id/tv_descripcion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:text="Evento sobre inteligencia artificial y más. Este es un texto más largo que puede ocupar varias líneas para probar el comportamiento del layout."
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/tv_hora_fin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_titulo_evento" />

        <!-- Hora de fin -->
        <TextView
            android:id="@+id/tv_hora_fin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="22:00"
            android:textColor="#60A5FA"
            android:textSize="12sp"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_descripcion"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>